{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div id="cm_adjust" class="section-{{ section.id }}-padding gradient color-{{ section.settings.section_color_scheme }}">
  <div class="page-width">
    {%- for block in section.blocks -%}
      <div
        class="about-us image-with-text image-with-text--no-overlap isolate{% if block.settings.layout == 'reverse' %} image-with-text--reverse{% endif %} scroll-trigger animate--slide-in"
        {{ block.shopify_attributes }}
      >
        <div class="image-with-text__grid grid grid--gapless grid--1-col grid--3-col-tablet">
          {%- if block.settings.layout == 'reverse' -%}
            <div class="image-with-text__text-item grid__item">
              <div class="image-with-text__content about-us__description">
                {%- if block.settings.heading != blank -%}
                  <h3 class="image-with-text__heading">
                    {{ block.settings.heading }}
                  </h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="image-with-text__text">{{ block.settings.text }}</p>
                {%- endif -%}
                {%- if block.settings.show_button -%}
                  <a href="{{ block.settings.button_link | default: '/' }}" class="button button--primary">
                    {{- block.settings.button_label -}}
                  </a>
                {%- endif -%}
              </div>
            </div>
            <div class="image-with-text__media-item image-with-text__media-item--{{ section.settings.desktop_image_width }} image-with-text__media-item--{{ section.settings.desktop_content_position }} grid__item">
              <div
                class="image-with-text__media image-with-text__media--{{ section.settings.height }} global-media-settings{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}{% if block.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}"
                {% if section.settings.height == 'adapt' and block.settings.image != blank %}
                  style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if block.settings.image != blank -%}
                  {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
                  {%- capture sizes -%}
                    (min-width: 768px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                    100vw
                  {%- endcapture -%}
                  {{
                    block.settings.image
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                  }}
                {%- else -%}
                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
          {%- else -%}
            <div class="image-with-text__media-item image-with-text__media-item--{{ section.settings.desktop_image_width }} image-with-text__media-item--{{ section.settings.desktop_content_position }} grid__item">
              <div
                class="image-with-text__media image-with-text__media--{{ section.settings.height }} global-media-settings{% unless remove_color_classes %} gradient color-{{ section.settings.color_scheme }}{% else %} background-transparent{% endunless %}{% if block.settings.image != blank %} media{% else %} image-with-text__media--placeholder placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}"
                {% if section.settings.height == 'adapt' and block.settings.image != blank %}
                  style="padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if block.settings.image != blank -%}
                  {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
                  {%- capture sizes -%}
                    (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                    (min-width: 768px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                  {%- endcapture -%}
                  {{
                    block.settings.image
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                  }}
                {%- else -%}
                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>
            <div class="image-with-text__text-item grid__item">
              <div class="image-with-text__content about-us__description">
                {%- if block.settings.heading != blank -%}
                  <h3 class="image-with-text__heading">
                    {{ block.settings.heading }}
                  </h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="image-with-text__text">{{ block.settings.text }}</p>
                {%- endif -%}
                {%- if block.settings.show_button -%}
                  <a href="{{ block.settings.button_link | default: '/' }}" class="button button--primary">
                    {{- block.settings.button_label -}}
                  </a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "私たちについて（画像+テキスト:3つ）",
  "class": "draggable-section",
  "settings": [
    { "type": "color_scheme", "id": "section_color_scheme", "label": "カラースキーム", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "画像 + テキスト",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "画像" },
        { "type": "richtext", "id": "heading", "label": "見出し", "default": "<p>デフォルトの見出し</p>" },
        { "type": "richtext", "id": "text", "label": "説明", "default": "<p>デフォルトの説明テキスト</p>" },
        { "type": "checkbox", "id": "show_button", "label": "ボタンを表示", "default": true },
        { "type": "text", "id": "button_label", "label": "ボタンテキスト", "default": "詳しく見る" },
        { "type": "url", "id": "button_link", "label": "ボタンリンク", "default": "/" },
        {
          "type": "select",
          "id": "layout",
          "label": "レイアウト",
          "options": [
            { "value": "default", "label": "画像左・テキスト右" },
            { "value": "reverse", "label": "画像右・テキスト左" }
          ],
          "default": "default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "私たちについて（画像+テキスト:3つ）",
      "blocks": [{ "type": "content_block" }, { "type": "content_block" }, { "type": "content_block" }]
    }
  ]
}
{% endschema %}
